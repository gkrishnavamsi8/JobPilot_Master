# JobPilot Master — environment template
# Copy relevant sections into each service's .env file.

# --- Parser (JobPilot-Parser/.env) ---
# DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
# UPLOAD_DIR=./data/uploads

# --- Scraper (Scraper Code/.env) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Autofill API (job-autofill-scraper/.env) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# PORT=3001
# API_KEY=optional-dev-key

# --- Ports (defaults) ---
# Parser API:   8002
# Scraper API:  8000
# Autofill API: 3001
# Frontend:     5173
