# --- Option 1: Supabase JS client (recommended) ---
# Get from: Project Settings → API
# SUPABASE_URL=https://aamvhktuijrwgrtucuij.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Option 2: Direct Postgres via Supabase pooler ---
# Replace [YOUR-PASSWORD] with your database password
# (Database Settings → Reset database password if you don't have it)
DATABASE_URL=postgresql://postgres.aamvhktuijrwgrtucuij:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session pooler — for migrations / direct SQL tools only (optional)
# DIRECT_URL=postgresql://postgres.aamvhktuijrwgrtucuij:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# API server port
PORT=3001

# Optional — if set, extension must send x-api-key header
# API_KEY=dev-api-key-change-me
