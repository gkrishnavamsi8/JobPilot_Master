# --- Storage backend: pick ONE ---
#
# Preferred: Supabase (PostgREST) - never exposes the DB password.
# Get the URL + service_role key from Supabase Dashboard -> Project Settings
# -> API. The service_role key bypasses RLS and can INSERT/UPDATE, which the
# scrape runner needs.
# SUPABASE_URL=https://aamvhktuijrwgrtucuij.supabase.co
# SUPABASE_SERVICE_KEY=sb_secret_...   (or an eyJ... service_role JWT)
#
# Alternative: direct Postgres (works with the CLI, too). Supabase's DB
# password lives at Dashboard -> Project Settings -> Database.
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.aamvhktuijrwgrtucuij.supabase.co:5432/postgres?sslmode=require

# Optional: CORS origins allowed by the API (comma-separated).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: connection pool upper bound (Postgres backend only).
# DB_POOL_MAX=5

# ...or discrete PG* env vars (used only if DATABASE_URL is empty).
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=jobpilot

# IANA timezone used when interpreting "today" for date filtering.
SCRAPE_TZ=Asia/Kolkata

# Bounded concurrency for detail-page fetches.
MAX_WORKERS=8

# Optional: override the User-Agent sent to the careers site.
# SCRAPER_USER_AGENT=jobpilot-scraper/0.1 (+https://github.com/your-org/jobpilot)

# Default --platform when the CLI flag is omitted.
# PLATFORM=astrazeneca

# --- Workday plugin ---
# Either set the full base URL...
# WORKDAY_BASE_URL=https://nvidia.wd5.myworkdayjobs.com/en-US/NVIDIAExternalCareerSite
# ...or the discrete parts:
# WORKDAY_HOST=nvidia.wd5.myworkdayjobs.com
# WORKDAY_TENANT=nvidia
# WORKDAY_LOCALE=en-US
# WORKDAY_SITE=NVIDIAExternalCareerSite
